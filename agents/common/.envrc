# Per-shell env for the agents/common Python harness.
# Activate via direnv (`direnv allow`) or by sourcing manually:
#   . agents/common/.envrc
#
# Public, portable bits only. Host-specific library discovery
# (LIBSTDCPP, LIBCLANG_PATH, LD_PRELOAD construction for nacre's pyo3) lives
# in `agents/common/.envrc.local`, which is gitignored. See
# `agents/common/.envrc.local.example` for a template.
#
# Override paths via env if your machine differs:
#   BINJA_PATH     - root of the Binary Ninja install (must contain .../python)
#   RUSTC_SYSROOT  - rustc sysroot (default: `rustc --print sysroot`)
#   LIBCLANG_PATH  - clang lib dir (set in .envrc.local on NixOS only)

export BINJA_PATH="${BINJA_PATH:-$HOME/down/binja/binaryninja-commerical/binaryninja}"
export RUSTC_SYSROOT="${RUSTC_SYSROOT:-$(rustc --print sysroot 2>/dev/null)}"
export BN_DISABLE_USER_PLUGINS=1
export BASE="$PWD"
export PYTHONPATH="$BINJA_PATH/python${PYTHONPATH:+:$PYTHONPATH}"

unset NIX_BUILD_TOP
export TMPDIR=/tmp

# Per-host library discovery (LD_PRELOAD construction, libclang autodiscovery,
# GLIBC_TUNABLES on NixOS, …). Sourced via plain `.` so this file works both
# under direnv and when sourced manually by scripts (utils/dev_install.sh).
if [ -f agents/common/.envrc.local ]; then
    . ./agents/common/.envrc.local
elif [ -f .envrc.local ]; then
    . ./.envrc.local      # we may have been sourced from agents/common/
fi
# `|| :` so `set -e` doesn't propagate the failed declare-test when sourced
# by plain bash (utils/dev_install.sh) outside direnv.
declare -F watch_file >/dev/null 2>&1 && watch_file agents/common/.envrc.local || :
