# Public, portable bits. Host-specific stuff (nix-store paths, BINJA_PATH,
# OPENSSL_DEV discovery, LD_LIBRARY_PATH...) lives in `.envrc.local`, which
# is gitignored. See `.envrc.local.example` for a template.

# Project-local binaries first on PATH.
export PATH="$PWD/target/release:$PATH"

# Generic NixOS escape hatch — harmless elsewhere.
unset NIX_BUILD_TOP
export TMPDIR=/tmp

# Per-host overrides + library discovery. Sourced before venv-activate so
# anything it sets (LD_LIBRARY_PATH, BINJA_PATH, etc.) flows through.
# Use plain `.` so this file works both under direnv AND when sourced
# directly by scripts (utils/dev_install.sh, ssh shells without direnv).
# `watch_file` makes direnv reload when .envrc.local changes; it's a no-op
# outside direnv.
if [ -f .envrc.local ]; then
    . ./.envrc.local
fi
# `watch_file` is a direnv stdlib helper. The `|| :` makes the line return 0
# under `set -e` when sourced by plain bash (utils/dev_install.sh), where
# `declare -F watch_file` is false and would otherwise propagate failure.
declare -F watch_file >/dev/null 2>&1 && watch_file .envrc.local || :

# Activate the project venv only if it exists. The venv is gitignored; fresh
# clones won't have one until the user runs whatever bootstrap they prefer
# (`uv sync`, `python -m venv agents/venv && pip install ...`, etc.).
if [ -f ./agents/venv/bin/activate ]; then
    source ./agents/venv/bin/activate
fi
